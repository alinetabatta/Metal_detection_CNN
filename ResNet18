import torch
import torch.nn as nn
from torchvision import models

device = torch.device("cuda" if torch.cuda.is_available() else "cpu")

model = models.resnet18(weights=models.ResNet18_Weights.IMAGENET1K_V1)


old_conv = model.conv1

model.conv1 = nn.Conv2d(
    in_channels=1,
    out_channels=64,
    kernel_size=7,
    stride=2,
    padding=3,
    bias=False
)

model.conv1.weight.data = old_conv.weight.data.mean(dim=1, keepdim=True)


num_features = model.fc.in_features
model.fc = nn.Linear(num_features, 2)  # METAL vs NoMETAL


for param in model.parameters():
    param.requires_grad = False

for param in model.fc.parameters():
    param.requires_grad = True


model = model.to(device)


criterion = nn.CrossEntropyLoss()
optimizer = torch.optim.Adam(model.fc.parameters(), lr=1e-3)


EPOCHS = 15

for epoch in range(EPOCHS):
    train_loss, train_acc = train_one_epoch(
        model, train_loader, optimizer, criterion, device
    )

    val_loss, val_acc = evaluate(
        model, val_loader, criterion, device
    )

    print(
        f"Epoch [{epoch+1}/{EPOCHS}] "
        f"Train Acc: {train_acc:.4f} | Val Acc: {val_acc:.4f}"
    )


test_loss, test_acc = evaluate(
    model, test_loader, criterion, device
)

print(f"ResNet18 (grayscale) Test Accuracy: {test_acc:.4f}")


for param in model.layer4.parameters():
    param.requires_grad = True


optimizer = torch.optim.Adam(
    [
        {"params": model.layer4.parameters()},
        {"params": model.fc.parameters()}
    ],
    lr=1e-4
)


FINE_TUNE_EPOCHS = 10

for epoch in range(FINE_TUNE_EPOCHS):
    train_loss, train_acc = train_one_epoch(
        model, train_loader, optimizer, criterion, device
    )

    val_loss, val_acc = evaluate(
        model, val_loader, criterion, device
    )

    print(
        f"[Fine-tune {epoch+1}/{FINE_TUNE_EPOCHS}] "
        f"Train Acc: {train_acc:.4f} | Val Acc: {val_acc:.4f}"
    )


test_loss, test_acc = evaluate(
    model, test_loader, criterion, device
)

print(f"ResNet18 (fine-tuned) Test Accuracy: {test_acc:.4f}")


import numpy as np
import torch
from sklearn.metrics import (
    confusion_matrix,
    roc_curve,
    auc
)

model.eval()

y_true = []
y_pred = []
y_prob = []  # probability of METAL (class 0)

with torch.no_grad():
    for images, labels in test_loader:
        images = images.to(device)
        labels = labels.to(device)

        outputs = model(images)
        probs = torch.softmax(outputs, dim=1)

        preds = torch.argmax(probs, dim=1)

        y_true.extend(labels.cpu().numpy())
        y_pred.extend(preds.cpu().numpy())
        y_prob.extend(probs[:, 0].cpu().numpy())  # 🔥 METAL probability


cm = confusion_matrix(
    y_true,
    y_pred,
    labels=[0, 1]  # [METAL, NoMETAL]
)

tn, fp, fn, tp = cm.ravel()

print("Confusion Matrix:")
print(cm)


sensitivity = tp / (tp + fn)   # Recall for METAL
specificity = tn / (tn + fp)

print(f"Sensitivity (METAL): {sensitivity:.4f}")
print(f"Specificity (NoMETAL): {specificity:.4f}")


fpr, tpr, thresholds = roc_curve(
    y_true,
    y_prob,
    pos_label=0  # 🔥 explicitly set METAL as positive
)

roc_auc = auc(fpr, tpr)

print(f"AUC (METAL): {roc_auc:.4f}")


import matplotlib.pyplot as plt

plt.figure()
plt.plot(fpr, tpr, label=f"AUC = {roc_auc:.3f}")
plt.plot([0, 1], [0, 1], linestyle="--")
plt.xlabel("False Positive Rate")
plt.ylabel("True Positive Rate")
plt.title("ROC Curve — METAL Detection")
plt.legend()
plt.grid(True)
plt.show()


fig, ax = plt.subplots(figsize=(6, 5))

